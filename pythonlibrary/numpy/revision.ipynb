import numpy as np

# ==========================================
# NUMPY TOP 20 MASTER CHEAT SHEET
# ==========================================

# --- 1. CREATION ---
arr = np.array([1, 2, 3])           # Create from list
zeros = np.zeros((3, 3))            # 3x3 matrix of 0s
ones = np.ones((2, 4))              # 2x4 matrix of 1s
rng = np.arange(0, 10, 2)           # [0, 2, 4, 6, 8] (Start, Stop, Step)
lin = np.linspace(0, 1, 5)          # 5 evenly spaced nums between 0 and 1
rand = np.random.rand(3, 3)         # 3x3 matrix of random floats (0 to 1)

# --- 2. INSPECTION ---
arr.shape                             # Dimensions (rows, cols)
arr.dtype                             # Data type (int64, float64)
arr.ndim                              # Number of dimensions
arr.size                              # Total number of elements

# --- 3. SELECTION & FILTERING ---
arr[0]                                # First element
arr[1:4]                              # Slicing (index 1 to 3)
matrix[1, 2]                          # Row 1, Column 2
arr[arr > 5]                          # Boolean mask: elements > 5
arr[(arr > 2) & (arr < 8)]            # Multiple conditions (Use & and |, not 'and'/'or')

# --- 4. MANIPULATION ---
arr.reshape(3, 2)                     # Change shape to 3x2 (Total elements must match)
arr.flatten()                         # Flatten any dimension back to 1D
np.append(arr, [99])                  # Add elements to the end
np.delete(arr, [0, 2])                # Delete elements at index 0 and 2

# --- 5. CLEANING ---
np.isnan(arr)                         # Returns boolean array of True where NaN exists
arr[~np.isnan(arr)]                   # Filter OUT NaNs
np.unique(arr)                        # Get sorted unique values (removes duplicates)
arr.astype(float)                     # Convert data type

# --- 6. MATH & AGGREGATION ---
arr.sum()                             # Sum of all elements
arr.mean()                            # Average
arr.max() / arr.min()                 # Maximum / Minimum
arr.sum(axis=0)                       # Sum down the columns (vertical)
arr.sum(axis=1)                       # Sum across the rows (horizontal)

# --- 7. COMBINING & FUNCTIONS ---
np.concatenate([a, b])                # Glue arrays together
np.vstack([a, b])                     # Stack vertically (rows)
np.hstack([a, b])                     # Stack horizontally (columns)
np.where(arr > 5, 'High', 'Low')      # If/Else logic on arrays
